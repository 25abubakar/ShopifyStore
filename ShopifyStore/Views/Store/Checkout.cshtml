@model CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
    var p = (Product)ViewBag.Product;
}

<div class="content-container py-4">
<div class="row justify-content-center">
    <div class="col-12 col-lg-7">
        <div class="form-card">
        <h3>Checkout - @p.Name</h3>
        <p>Unit Price: <strong>PKR @p.PricePkr</strong></p>
        <p class="text-muted">Payment options: COD, Bank Transfer, Easypaisa/JazzCash and online gateway placeholder.</p>
        <form method="post">
            @Html.AntiForgeryToken()
            <input asp-for="ProductId" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-2">
                <label asp-for="CustomerName" class="form-label"></label>
                <input asp-for="CustomerName" class="form-control" />
            </div>
            <div class="mb-2">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" />
            </div>
            <div class="mb-2">
                <label asp-for="Address" class="form-label"></label>
                <textarea asp-for="Address" class="form-control"></textarea>
            </div>
            <div class="mb-2">
                <label asp-for="Quantity" class="form-label"></label>
                <input asp-for="Quantity" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="PaymentMethod" class="form-label"></label>
                <select asp-for="PaymentMethod" id="paymentMethod" class="form-select" asp-items="Html.GetEnumSelectList<PaymentMethod>()"></select>
            </div>
            <div id="manualPaymentFields" class="border rounded p-3 mb-3 bg-light d-none">
                <h6>Manual Payment Details</h6>
                <p class="small mb-2">Bank: Meezan Bank - 0312-XXXXXXX / IBAN PK00MEEZ0000000000</p>
                <p class="small mb-2">Wallet: Easypaisa/JazzCash - 03XX-XXXXXXX</p>
                <div class="mb-2">
                    <label asp-for="PaymentReference" class="form-label">Payment Reference / Transaction ID</label>
                    <input asp-for="PaymentReference" class="form-control" placeholder="e.g TXN-12345678" />
                    <span asp-validation-for="PaymentReference" class="text-danger"></span>
                </div>
                <div class="mb-2">
                    <label asp-for="PaymentScreenshotUrl" class="form-label"></label>
                    <input asp-for="PaymentScreenshotUrl" class="form-control" placeholder="Paste screenshot URL or drive link" />
                    <span asp-validation-for="PaymentScreenshotUrl" class="text-danger"></span>
                </div>
            </div>
            <div id="gatewayNotice" class="alert alert-info d-none">
                Online gateway is configured as a placeholder in this build. Order will be marked gateway-pending until payment confirmation.
            </div>
            <button class="btn btn-primary">Place Order</button>
        </form>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const paymentMethod = document.getElementById("paymentMethod");
        const manualPaymentFields = document.getElementById("manualPaymentFields");
        const gatewayNotice = document.getElementById("gatewayNotice");
        const togglePaymentFields = () => {
            const value = paymentMethod.value;
            const isManualTransfer = value === "BankTransfer" || value === "EasypaisaOrJazzCash" || value === "2" || value === "3";
            const isGateway = value === "OnlineGateway" || value === "4";
            manualPaymentFields.classList.toggle("d-none", !isManualTransfer);
            gatewayNotice.classList.toggle("d-none", !isGateway);
        };
        paymentMethod.addEventListener("change", togglePaymentFields);
        togglePaymentFields();
    </script>
}
