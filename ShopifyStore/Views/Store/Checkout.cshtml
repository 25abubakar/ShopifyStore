@model CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
    var p = (Product)ViewBag.Product;
}

<div class="row">
    <div class="col-md-6">
        <h3>Checkout - @p.Name</h3>
        <p>Unit Price: <strong>PKR @p.PricePkr</strong></p>
        <p class="text-muted">Bank Transfer (Pakistan): Meezan Bank - 0312-xxxxxxx / IBAN PK00MEEZ0000000000</p>
        <form method="post">
            <input asp-for="ProductId" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-2">
                <label asp-for="CustomerName" class="form-label"></label>
                <input asp-for="CustomerName" class="form-control" />
            </div>
            <div class="mb-2">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" />
            </div>
            <div class="mb-2">
                <label asp-for="Address" class="form-label"></label>
                <textarea asp-for="Address" class="form-control"></textarea>
            </div>
            <div class="mb-2">
                <label asp-for="Quantity" class="form-label"></label>
                <input asp-for="Quantity" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="PaymentMethod" class="form-label"></label>
                <select asp-for="PaymentMethod" class="form-select" asp-items="Html.GetEnumSelectList<PaymentMethod>()"></select>
            </div>
            <button class="btn btn-primary">Place Order</button>
        </form>
    </div>
</div>
