@model CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
    var p = (Product)ViewBag.Product;
}

<div class="row">
    <div class="col-md-6">
        <h3>Checkout - @p.Name</h3>
        <p>Unit Price: <strong>PKR @p.PricePkr</strong></p>
        <p class="text-muted">Bank Transfer (Pakistan): Meezan Bank - 0312-xxxxxxx / IBAN PK00MEEZ0000000000</p>
        <form method="post">
            @Html.AntiForgeryToken()
            <input asp-for="ProductId" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-2">
                <label asp-for="CustomerName" class="form-label"></label>
                <input asp-for="CustomerName" class="form-control" />
            </div>
            <div class="mb-2">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control" />
            </div>
            <div class="mb-2">
                <label asp-for="Address" class="form-label"></label>
                <textarea asp-for="Address" class="form-control"></textarea>
            </div>
            <div class="mb-2">
                <label asp-for="Quantity" class="form-label"></label>
                <input asp-for="Quantity" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="PaymentMethod" class="form-label"></label>
                <select asp-for="PaymentMethod" id="paymentMethod" class="form-select" asp-items="Html.GetEnumSelectList<PaymentMethod>()"></select>
            </div>
            <div id="bankTransferFields" class="border rounded p-3 mb-3 bg-light d-none">
                <h6>Bank Transfer Details</h6>
                <p class="small mb-2">Send amount to: Meezan Bank - Account 0312-XXXXXXX / IBAN PK00MEEZ0000000000</p>
                <div class="mb-2">
                    <label asp-for="BankTransactionId" class="form-label"></label>
                    <input asp-for="BankTransactionId" class="form-control" placeholder="e.g TXN-12345678" />
                    <span asp-validation-for="BankTransactionId" class="text-danger"></span>
                </div>
                <div class="mb-2">
                    <label asp-for="PaymentScreenshotUrl" class="form-label"></label>
                    <input asp-for="PaymentScreenshotUrl" class="form-control" placeholder="Paste screenshot URL or drive link" />
                    <span asp-validation-for="PaymentScreenshotUrl" class="text-danger"></span>
                </div>
            </div>
            <button class="btn btn-primary">Place Order</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const paymentMethod = document.getElementById("paymentMethod");
        const bankTransferFields = document.getElementById("bankTransferFields");
        const toggleBankFields = () => {
            const isBankTransfer = paymentMethod.value === "BankTransfer" || paymentMethod.value === "2";
            bankTransferFields.classList.toggle("d-none", !isBankTransfer);
        };
        paymentMethod.addEventListener("change", toggleBankFields);
        toggleBankFields();
    </script>
}
