@model Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="content-container py-4">
<div class="row g-4">
    <div class="col-12 col-md-5">
        <img src="@Model.ImageUrl" class="img-fluid rounded shadow-sm product-detail-image" alt="@Model.Name" />
    </div>
    <div class="col-12 col-md-7">
        <h2>@Model.Name</h2>
        <p class="text-muted">@Model.Department / @Model.Category / @Model.Subcategory</p>
        <p class="mb-1"><strong>Brand:</strong> @Model.Brand</p>
        <p class="mb-1"><strong>SKU:</strong> @Model.Sku</p>
        <p class="mb-1"><strong>Color:</strong> @Model.Color | <strong>Size:</strong> @Model.Size</p>
        <p class="mb-1"><strong>Material:</strong> @Model.Material</p>
        <p class="mb-1"><strong>Origin:</strong> @Model.CountryOfOrigin</p>
        <p>@Model.Description</p>
        <h4>PKR @Model.PricePkr</h4>
        @if (Model.DiscountPercent > 0)
        {
            <p class="text-success mb-1"><strong>Discount:</strong> @Model.DiscountPercent%</p>
        }
        <p>Available: @Model.Stock</p>
        @if (!string.IsNullOrWhiteSpace(Model.CareInstructions))
        {
            <p class="small text-muted"><strong>Care:</strong> @Model.CareInstructions</p>
        }
        <a class="btn btn-success w-100 w-md-auto" asp-action="Checkout" asp-route-productId="@Model.Id">Buy Now</a>
    </div>
</div>

<hr />
<h4>Customer Reviews</h4>
<div class="row g-3">
    <div class="col-12 col-md-6">
        <form method="post" asp-controller="Reviews" asp-action="Create">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ProductId" value="@Model.Id" />
            <div class="mb-2">
                <label class="form-label">Name</label>
                <input name="CustomerName" class="form-control" required />
            </div>
            <div class="mb-2">
                <label class="form-label">Rating (1-5)</label>
                <input name="Rating" type="number" min="1" max="5" class="form-control" required />
            </div>
            <div class="mb-2">
                <label class="form-label">Comment</label>
                <textarea name="Comment" class="form-control" required></textarea>
            </div>
            <button class="btn btn-dark">Submit Review</button>
        </form>
    </div>
    <div class="col-12 col-md-6">
        @if (!Model.Reviews.Any())
        {
            <p class="text-muted">No reviews yet.</p>
        }
        else
        {
            @foreach (var r in Model.Reviews)
            {
                <div class="border rounded p-2 mb-2">
                    <strong>@r.CustomerName</strong> - <span>@r.Rating/5</span>
                    <div>@r.Comment</div>
                </div>
            }
        }
    </div>
</div>
</div>
