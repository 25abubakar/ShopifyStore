@model StoreIndexViewModel
@{
    ViewData["Title"] = "Store";
}

<section class="hero-section" style="background-image: linear-gradient(90deg, rgba(0,0,0,0.5), rgba(0,0,0,0.15)), url('@Model.HeroImageUrl');">
    <div class="hero-overlay">
        <p class="hero-kicker">NEW ARRIVAL</p>
        <h1>@Model.HeroTitle</h1>
        <p class="hero-sub">@Model.HeroSubtitle</p>
        <div class="hero-actions">
            <a class="btn btn-light hero-btn" asp-action="Index" asp-route-department="Women">SHOP WOMEN</a>
            <a class="btn btn-outline-light hero-btn" asp-action="Index" asp-route-department="Men">SHOP MEN</a>
            <a class="btn btn-outline-light hero-btn" asp-action="Index" asp-route-department="Beauty">SHOP BEAUTY</a>
        </div>
    </div>
</section>

<section class="store-toolbar container py-4">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-12 col-md-2">
            <label class="form-label">Department</label>
            <select name="department" class="form-select">
                <option value="">All</option>
                @foreach (var d in Model.Departments)
                {
                    <option value="@d" selected="@(Model.Department == d)">@d</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label">Category</label>
            <select name="category" class="form-select">
                <option value="">All</option>
                @foreach (var c in Model.Categories)
                {
                    <option value="@c" selected="@(Model.Category == c)">@c</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label">Subcategory</label>
            <select name="subcategory" class="form-select">
                <option value="">All</option>
                @foreach (var s in Model.Subcategories)
                {
                    <option value="@s" selected="@(Model.Subcategory == s)">@s</option>
                }
            </select>
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label">Search</label>
            <input name="search" class="form-control" value="@Model.Search" />
        </div>
        <div class="col-6 col-md-1">
            <label class="form-label">Min</label>
            <input name="minPrice" type="number" class="form-control" value="@Model.MinPrice" />
        </div>
        <div class="col-6 col-md-1">
            <label class="form-label">Max</label>
            <input name="maxPrice" type="number" class="form-control" value="@Model.MaxPrice" />
        </div>
        <div class="col-12 col-md-2">
            <label class="form-label">Sort</label>
            <select name="sortBy" class="form-select">
                <option value="name" selected="@(Model.SortBy == "name")">Name</option>
                <option value="newest" selected="@(Model.SortBy == "newest")">Newest</option>
                <option value="price_asc" selected="@(Model.SortBy == "price_asc")">Price Low to High</option>
                <option value="price_desc" selected="@(Model.SortBy == "price_desc")">Price High to Low</option>
            </select>
        </div>
        <div class="col-12">
            <div class="form-check">
                @if (Model.InStockOnly)
                {
                    <input class="form-check-input" type="checkbox" name="inStockOnly" value="true" checked id="inStockOnly" />
                }
                else
                {
                    <input class="form-check-input" type="checkbox" name="inStockOnly" value="true" id="inStockOnly" />
                }
                <label class="form-check-label" for="inStockOnly">In stock only</label>
            </div>
        </div>
        <div class="col-12 d-flex gap-2">
            <button class="btn btn-dark">Apply Filters</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
        </div>
    </form>
</section>

<section class="product-section container pb-5">
    <div class="row g-4">
        @foreach (var product in Model.Products)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <article class="product-card">
                    <a asp-action="Product" asp-route-id="@product.Id" class="product-img-wrap">
                        <img src="@product.ImageUrl" class="product-img" alt="@product.Name">
                    </a>
                    <div class="product-body">
                        <div class="product-category">@product.Department / @product.Category / @product.Subcategory</div>
                        <h3 class="product-name">@product.Name</h3>
                        <div class="small text-muted">@product.Brand | @product.Sku</div>
                        <div class="product-price">Rs. @product.PricePkr</div>
                        @if (product.DiscountPercent > 0)
                        {
                            <div class="small text-success">Discount: @product.DiscountPercent%</div>
                        }
                        <div class="product-stock">Stock: @product.Stock</div>
                        <a class="btn btn-dark w-100 mt-2" asp-action="Product" asp-route-id="@product.Id">View Product</a>
                    </div>
                </article>
            </div>
        }
    </div>
</section>

<section class="promo-strip">
    <div class="container py-4">
        <div class="row text-center g-3">
            <div class="col-md-4"><strong>Nationwide Delivery</strong><div>Fast shipping across Pakistan</div></div>
            <div class="col-md-4"><strong>Secure Payments</strong><div>COD + Bank Transfer supported</div></div>
            <div class="col-md-4"><strong>Easy Management</strong><div>Add/Edit your own products anytime</div></div>
        </div>
    </div>
</section>
