@model IEnumerable<Product>
@{
    ViewData["Title"] = "Store";
    var categories = ViewBag.Categories as List<string> ?? [];
    var active = ViewBag.ActiveCategory as string;
}

<section class="hero-section">
    <div class="hero-overlay">
        <p class="hero-kicker">NEW ARRIVAL</p>
        <h1>New Sustainable<br />Knits & Styles</h1>
        <p class="hero-sub">Premium quality fashion for Pakistan with COD and bank transfer available.</p>
        <div class="hero-actions">
            <a class="btn btn-light hero-btn" asp-action="Index">SHOP WOMEN</a>
            <a class="btn btn-outline-light hero-btn" asp-action="Index" asp-route-category="Men">SHOP MEN</a>
        </div>
    </div>
</section>

<section class="store-toolbar container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
        <h2 class="section-title mb-0">All Products</h2>
        <div class="category-chips">
            <a class="chip @(string.IsNullOrWhiteSpace(active) ? "active" : "")" asp-action="Index">All</a>
            @foreach (var c in categories)
            {
                <a class="chip @(active == c ? "active" : "")" asp-action="Index" asp-route-category="@c">@c</a>
            }
        </div>
    </div>
</section>

<section class="product-section container pb-5">
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <article class="product-card">
                    <a asp-action="Product" asp-route-id="@product.Id" class="product-img-wrap">
                        <img src="@product.ImageUrl" class="product-img" alt="@product.Name">
                    </a>
                    <div class="product-body">
                        <div class="product-category">@product.Category</div>
                        <h3 class="product-name">@product.Name</h3>
                        <div class="product-price">Rs. @product.PricePkr</div>
                        <div class="product-stock">Stock: @product.Stock</div>
                        <a class="btn btn-dark w-100 mt-2" asp-action="Product" asp-route-id="@product.Id">View Product</a>
                    </div>
                </article>
            </div>
        }
    </div>
</section>

<section class="promo-strip">
    <div class="container py-4">
        <div class="row text-center g-3">
            <div class="col-md-4"><strong>Nationwide Delivery</strong><div>Fast shipping across Pakistan</div></div>
            <div class="col-md-4"><strong>Secure Payments</strong><div>COD + Bank Transfer supported</div></div>
            <div class="col-md-4"><strong>Easy Management</strong><div>Add/Edit your own products anytime</div></div>
        </div>
    </div>
</section>
