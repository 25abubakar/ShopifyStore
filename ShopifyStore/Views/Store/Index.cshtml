@model IEnumerable<Product>
@{
    ViewData["Title"] = "Store";
    var categories = ViewBag.Categories as List<string> ?? [];
    var active = ViewBag.ActiveCategory as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>All Products</h2>
    <div>
        <a class="btn btn-outline-dark btn-sm @(string.IsNullOrWhiteSpace(active) ? "active" : "")" asp-action="Index">All</a>
        @foreach (var c in categories)
        {
            <a class="btn btn-outline-dark btn-sm @(active == c ? "active" : "")" asp-action="Index" asp-route-category="@c">@c</a>
        }
    </div>
</div>

<div class="row g-3">
    @foreach (var product in Model)
    {
        <div class="col-md-3">
            <div class="card h-100 shadow-sm">
                <img src="@product.ImageUrl" class="card-img-top" style="height:180px; object-fit:cover;" alt="@product.Name">
                <div class="card-body d-flex flex-column">
                    <h5>@product.Name</h5>
                    <small class="text-muted">@product.Category</small>
                    <p class="mt-2 mb-1">PKR @product.PricePkr</p>
                    <p class="small text-muted">Stock: @product.Stock</p>
                    <a class="btn btn-dark mt-auto" asp-action="Product" asp-route-id="@product.Id">View</a>
                </div>
            </div>
        </div>
    }
</div>
