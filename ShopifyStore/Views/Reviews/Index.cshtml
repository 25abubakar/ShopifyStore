@model IEnumerable<Review>
@{
    ViewData["Title"] = "Manage Reviews";
}

<h3>Reviews</h3>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Product</th>
            <th>Customer</th>
            <th>Rating</th>
            <th>Comment</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var r in Model)
    {
        <tr>
            <td>@r.Product?.Name</td>
            <td>@r.CustomerName</td>
            <td>@r.Rating</td>
            <td>@r.Comment</td>
            <td>
                @if (User.IsInRole("CEO") || User.IsInRole("Admin"))
                {
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@r.Id">Delete</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
