@model IEnumerable<ProductAdminRowViewModel>
@{
    ViewData["Title"] = "Manage Products";
}

<div class="content-container">
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h3 class="mb-0">Products CRUD</h3>
    @if (User.IsInRole("CEO") || User.IsInRole("Admin"))
    {
        <a class="btn btn-success" asp-action="Create">Add Product</a>
    }
</div>

<div class="table-responsive">
<table class="table table-striped align-middle products-grid-table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Department</th>
            <th>Category</th>
            <th>Subcategory</th>
            <th>Brand</th>
            <th>SKU</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Qty Sold</th>
            <th>Qty Held</th>
            <th>Qty Available</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Name</td>
            <td>@p.Department</td>
            <td>@p.Category</td>
            <td>@p.Subcategory</td>
            <td>@p.Brand</td>
            <td>@p.Sku</td>
            <td>@p.PricePkr</td>
            <td>@p.Stock</td>
            <td>@p.QtySold</td>
            <td>@p.QtyHeld</td>
            <td>@p.QtyAvailable</td>
            <td>
                @if (User.IsInRole("CEO") || User.IsInRole("Admin"))
                {
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@p.ProductId">Edit</a>
                }
                @if (User.IsInRole("CEO"))
                {
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@p.ProductId">Delete</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
</div>
